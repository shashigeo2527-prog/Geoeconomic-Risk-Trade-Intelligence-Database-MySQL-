SELECT category,
       ROUND(AVG(supply_risk),2) AS avg_supply_risk
FROM strategicgoods
GROUP BY category
ORDER BY avg_supply_risk DESC;
SELECT good_name,
       strategic_imp_score,
       supply_risk,
       (strategic_imp_score + supply_risk) AS combined_risk
FROM strategicgoods
ORDER BY combined_risk DESC;
