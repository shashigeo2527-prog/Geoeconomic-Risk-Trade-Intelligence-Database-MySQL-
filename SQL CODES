create datAbase geoeconomics_risk_analysis;
USE GEOECONOMICS_RISK_ANALYSIS;
CREATE TABLE COUNTRIES(
COUNTRY_ID INT PRIMARY KEY,
COUNTRY_NAME VARCHAR(50),
ISO_CODE VARCHAR(10),
REGION VARCHAR(50),
SUBREGION VARCHAR(50),
GDP_USMILL BIGINT,
CURRENCY VARCHAR(50),
POPULATION BIGINT,
POLITICAL_ALL VARCHAR(50),
RISK_LEVEL VARCHAR(50)
);
SELECT * FROM COUNTRIES;
CREATE TABLE TRADE_FLOWS(
TRADE_ID INT PRIMARY KEY,
YEAR INT,
IMPORTER_COUNTRY VARCHAR(50),
EXPORTER_COUNTRY VARCHAR(50),
COMMODITY VARCHAR(200),
TRDAE_FLOW  VARCHAR(200),
TRADE_VALUE BIGINT,
STRATEGIC_CAT  VARCHAR(200),
DEPENDENCY_PERCENT FLOAT, 
SUPPLY_RISK FLOAT,
VULNERABILITY_SCORE float
);
SELECT*FROM TRADE_FLOWS;

CREATE TABLE SANCTIONS(
SANCTION_ID INT,
SANCTIONED_ENTITY VARCHAR(255),
ENTITY_TYPE VARCHAR(60),
SANCTION_PROGRAM VARCHAR(255),
COUNTRY VARCHAR(100),
SANCTIONING_AUTHORITY VARCHAR(100),
SANCTIONINF_TARGETED VARCHAR(100),
SEVERITY_SCORE INT,
SANCTION_YEAR INT
);
SELECT*FROM Sanctions;

CREATE TABLE STRATEGICGOODS(
GOOD_ID INT PRIMARY KEY,
GOOD_NAME VARCHAR(100), 
HS_CODE VARCHAR(20),
CATEGORY VARCHAR(20),
STRATEGIC_IMP_SCORE INT,
SUPPLY_RISK int
);

SELECT*FROM STRATEGICGOODS;

