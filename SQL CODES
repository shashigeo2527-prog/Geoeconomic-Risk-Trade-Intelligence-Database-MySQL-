WHERE dependency_percent > 50
ORDER BY dependency_percent DESC;
sELECT * FROM trade_flows
WHERE commodity = 'Alkali or alkaline-earth metals; rare-earth metals, scandium and yttrium, whether or not intermixed or interalloyed; mercury';
SELECT *
FROM trade_flows
WHERE importer_country = 'USA'
OR exporter_country = 'USA';

SELECT commodity,
       SUM(trade_value) AS total_trade
FROM trade_flows
GROUP BY commodity
ORDER BY total_trade DESC;

